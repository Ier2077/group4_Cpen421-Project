# Shared
JWT_SECRET=super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database credentials (shared user, different DBs per service)
DB_USER=erp_user
DB_PASS=erp_pass

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672

# Redis
REDIS_URL=redis://redis:6379/0

# Service URLs (used by incident_service)
DISPATCH_SERVICE_URL=http://dispatch_service:8003
AUTH_SERVICE_URL=http://auth_service:8001